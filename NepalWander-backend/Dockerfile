# ── Base image ────────────────────────────────────────
FROM node:20-alpine

# ── Set working directory ─────────────────────────────
WORKDIR /app

# ── Copy package files first (layer caching) ─────────
COPY package*.json ./

# ── Install dependencies ──────────────────────────────
RUN npm ci --only=production

# ── Copy source code ──────────────────────────────────
COPY . .

# ── Build TypeScript ──────────────────────────────────
RUN npm run build

# ── Expose port ───────────────────────────────────────
EXPOSE 5000

# ── Start server ──────────────────────────────────────
CMD ["node", "dist/server.js"]